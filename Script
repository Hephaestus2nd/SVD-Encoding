% Gram-Schmidt process function to orthonormalize columns of a matrix
function Q = gramSchmidt(A)
   [n, m] = size(A);
   Q = sym(zeros(n, m));
   for j = 1:m
       v = A(:, j);
        for i = 1:j-1
           v = v - (Q(:, i).' * v) * Q(:, i);
       end
       v_norm = norm(v);
       if v_norm == 0
           error('Gram-Schmidt failed: Zero vector in column %d.', j);
       end
       Q(:, j) = v / v_norm;
   end
end

% function Q = gramSchmidt(A)
% %MGSON Modified Gram-Schmidt Orthonormalization
% %   Q = mgson(A) returns an orthonormal basis Q for the columns of A
% %   using the Modified Gram-Schmidt process.
% 
%     [n, m] = size(A);
%     Q = sym(zeros(n, m));
%     V = A; % Copy of A to work on
% 
%     for i = 1:m
%         % Normalize the current vector
%         v_norm = norm(V(:, i));
%         if v_norm < eps(class(V))
%             error('Column %d is linearly dependent on previous columns.', i);
%         end
%         Q(:, i) = V(:, i) / v_norm;
% 
%         % Orthogonalize the remaining vectors
%         for j = i+1:m
%             V(:, j) = V(:, j) - (Q(:, i)' * V(:, j)) * Q(:, i);
%         end
%     end
% end
% Function to generate a symbolic matrix with high precision
% Symbolic random matrix generator
function R = randSym(n, d)
    R = sym(zeros(n));
    for i = 1:n
        for j = 1:n
            R(i, j) = vpa(2*rand() - 1, d);  % Random values in [-1, 1]
        end
    end
end

