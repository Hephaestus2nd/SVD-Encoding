% CSV saver (no headers, Excel-friendly)
function saveForExcel(filename, matrix)
    fid = fopen(filename, 'w');
    [rows, cols] = size(matrix);
    for i = 1:rows
        row_values = arrayfun(@(j) sprintf('"%s"', formatValue(matrix(i, j))), 1:cols, 'UniformOutput', false);
        fprintf(fid, '%s\n', strjoin(row_values, ','));
    end
    fclose(fid);
end

function str = formatValue(val)
    % Convert to 50-digit string, replacing invalid entries with "0"
    val_str = char(vpa(val, 50));
    if isempty(val_str) || contains(val_str, 'NaN') || contains(val_str, 'Inf')
        str = '0';
    else
        % Ensure scientific notation uses 'e' (not 'E') and has full exponent
        val_str = strrep(val_str, 'E', 'e');
        if contains(val_str, 'e')
            parts = strsplit(val_str, 'e');
            exponent = num2str(str2num(parts{2})); %#ok<ST2NM>
            val_str = [parts{1}, 'e', exponent];
        end
        str = val_str;
    end
end
function matrix_loaded = loadFromExcel(filename)
    opts = detectImportOptions(filename, 'NumHeaderLines', 0);
    opts = setvartype(opts, 'string');  % Treat everything as strings

    data = readmatrix(filename, opts);  % Read as strings
    [rows, cols] = size(data);
    matrix_loaded = sym(zeros(rows, cols));  % Preallocate symbolic matrix

    for i = 1:rows
        for j = 1:cols
            str = strtrim(data(i, j));  % Remove leading/trailing whitespace

            try
                % Only try converting if string is non-empty and not just quotes
                if str ~= "" && str ~= '""'
                    matrix_loaded(i, j) = vpa(str2sym(str), 50);
                else
                    warning('Empty or invalid string at (%d, %d); replacing with NaN', i, j);
                    matrix_loaded(i, j) = sym(NaN);
                end
            catch ME
                warning('Failed to convert string at (%d, %d): "%s"\nError: %s', ...
                    i, j, str, ME.message);
                matrix_loaded(i, j) = sym(NaN);
            end
        end
    end
end
